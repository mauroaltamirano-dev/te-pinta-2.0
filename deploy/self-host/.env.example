# Puerto LAN de la app en la notebook: http://IP_DE_LA_NOTEBOOK:8080
WEB_PORT=8080

# Para uso real con Cloudflare Tunnel, usar el dominio HTTPS final.
# Para prueba local/LAN, puede ser http://localhost:8080 o http://IP_DE_LA_NOTEBOOK:8080.
ALLOWED_ORIGIN=https://te-pinta.tu-dominio.com
NODE_ENV=production

# Generar valores largos. Ejemplo: openssl rand -hex 32
POSTGRES_PASSWORD=change-this-postgres-password
JWT_SECRET=replace-with-at-least-32-random-chars
JWT_REFRESH_SECRET=replace-with-a-different-32-random-chars

# Admin inicial. El seed actualiza este usuario si lo volvés a correr.
ADMIN_EMAIL=admin@tepinta.local
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=Admin Te Pinta

# Opcional: token de Cloudflare Tunnel si querés publicar sin abrir puertos.
CLOUDFLARE_TUNNEL_TOKEN=
