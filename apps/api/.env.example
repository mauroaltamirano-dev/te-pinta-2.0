DATABASE_URL=postgres://user:password@localhost:5432/te_pinta
JWT_SECRET=replace-with-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret
ALLOWED_ORIGIN=http://localhost:5173
ADMIN_EMAIL=admin@tepinta.local
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=Admin Te Pinta
PORT=3000
NODE_ENV=development

# Herramientas manuales de importación. No son necesarias para iniciar el API.
LEGACY_DATABASE_URL=postgres://legacy_user:legacy_password@localhost:5433/legacy_te_pinta
OLD_NEON_DATABASE_URL=postgres://old_user:old_password@localhost:5434/old_te_pinta
NEW_NEON_DATABASE_URL=postgres://new_user:new_password@localhost:5435/new_te_pinta
